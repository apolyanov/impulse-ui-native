{
  "name": "@impulse-ui-native/endpoint",
  "version": "1.0.10",
  "source": "src/index.ts",
  "module": "dist/index.js",
  "types": "dist/index.d.mts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm exec eslint . --fix",
    "format": "prettier --write \"./**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path ../../.prettierignore"
  },
  "devDependencies": {
    "@impulse-ui-native/eslint-config": "workspace:*",
    "@impulse-ui-native/prettier-config": "workspace:*",
    "@impulse-ui-native/tsconfig": "workspace:*",
    "@types/react": "catalog:react19",
    "axios": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:react19",
    "react-native": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73",
    "@tanstack/react-query": ">=5.0.0",
    "axios": ">=1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@impulse-ui-native/prettier-config"
}
