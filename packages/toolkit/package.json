{
  "name": "@impulse-ui-native/toolkit",
  "version": "1.0.10",
  "source": "src/index.ts",
  "module": "dist/index.js",
  "types": "dist/index.d.mts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm exec eslint . --fix",
    "format": "prettier --write \"./**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@impulse-ui-native/core": "workspace:*",
    "@impulse-ui-native/echo": "workspace:*",
    "@impulse-ui-native/endpoint": "workspace:*",
    "@impulse-ui-native/flyout": "workspace:*",
    "@impulse-ui-native/icon": "workspace:*",
    "@impulse-ui-native/stepper": "workspace:*",
    "@impulse-ui-native/input": "workspace:*",
    "@impulse-ui-native/layers": "workspace:*",
    "@impulse-ui-native/types": "workspace:*",
    "@impulse-ui-native/theme": "workspace:*",
    "@impulse-ui-native/primitives": "workspace:*",
    "@impulse-ui-native/data-state": "workspace:*",
    "@impulse-ui-native/skeleton": "workspace:*",
    "@impulse-ui-native/select": "workspace:*",
    "@impulse-ui-native/portal": "workspace:*",
    "@impulse-ui-native/datetime": "workspace:*"
  },
  "devDependencies": {
    "@impulse-ui-native/eslint-config": "workspace:*",
    "@impulse-ui-native/prettier-config": "workspace:*",
    "@impulse-ui-native/tsconfig": "workspace:*",
    "@types/react": "catalog:react19",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:react19",
    "react-native": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@shopify/flash-list": ">=2",
    "react": ">=18",
    "react-native": ">=0.73",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.6.0",
    "react-native-safe-area-context": ">=5.0.0",
    "react-native-svg": ">=13.9.0",
    "react-native-worklets": ">=0.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@impulse-ui-native/prettier-config"
}
