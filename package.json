{
  "name": "impulse-ui-native",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "dev": "turbo run dev",
    "version-packages": "changeset version",
    "publish-packages": "node scripts/changeset-publish.mjs",
    "release": "pnpm run build && pnpm run publish-packages",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@impulse-ui-native/prettier-config": "workspace:*",
    "@types/node": "catalog:",
    "prettier": "catalog:",
    "tsup": "^8.5.0",
    "turbo": "^2.9.7",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "^22.21.0",
    "pnpm": "^10.19.0"
  },
  "prettier": "@impulse-ui-native/prettier-config"
}
